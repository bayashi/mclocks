#!/usr/bin/env bash

# Open a supported source file in mclocks via POST /preview

set -euo pipefail

usage() {
	echo "usage: mc-preview PATH/TO/file.(md|json|yaml|…)" >&2
	exit 1
}

[ "$#" -ge 1 ] || usage

FILE="$*"
lc=$(printf '%s' "$FILE" | tr '[:upper:]' '[:lower:]')
case "$lc" in
*.md|*.markdown|*.json|*.yaml|*.yml|*.toml|*.xml|*.ini|*.config|*.cfg) ;;
*)
	echo "mc-preview: unsupported extension (need .md, .json, .yaml, .yml, .toml, .xml, .ini, .config, .cfg, …)" >&2
	exit 1
	;;
esac

HOST="${MCLOCKS_WEB_HOST:-127.0.0.1}"
PORT="${MCLOCKS_WEB_PORT:-3030}"

URL="http://${HOST}:${PORT}/preview"

printf '%s\n%s' "$FILE" "$(pwd -P)" | curl -sS -X POST "$URL" --data-binary @-
